      "mode": "code",
      "code_content": "df_modified = df.group_by([\"sample\", \"depth\"]).agg([\n    pl.col(\"faith_pd\").mean().alias(\"mean\"),\n    pl.col(\"faith_pd\").std().alias(\"std\")\n]).sort(\"depth\")\n\nfig = px.line(\n    df_modified.to_pandas(),\n    x=\"depth\", y=\"mean\", color=\"sample\",\n    error_y=\"std\", markers=True,\n    labels={\"depth\": \"Rarefaction Depth\", \"mean\": \"Faith's Phylogenetic Diversity\"},\n    title=\"Alpha Diversity Rarefaction Curves\"\n)\nfig.update_traces(mode=\"lines+markers\")",
