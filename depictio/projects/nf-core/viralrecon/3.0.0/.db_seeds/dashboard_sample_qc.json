      "visu_type": "scatter",
      "dict_kwargs": {},
      "mode": "code",
      "code_content": "fig = px.scatter(df.to_pandas(), x='coverage_median', y='num_variants_total',\n    color='lineage', hover_data=['sample', 'pct_genome_covered_10x'],\n    labels={'coverage_median': 'Median Coverage Depth', 'num_variants_total': 'Total Variants', 'lineage': 'Lineage'},\n    size_max=12)\nfig.update_traces(marker=dict(size=10, line=dict(width=1, color='DarkSlateGrey')))\n",
