    {
      "index": "172cd937-94bf-4a07-8006-697d6e6dc057",
      "component_type": "text",
      "title": "Palmer Penguins \u2014 Species & Island Morphology",
      "workflow_tag": "",
      "data_collection_tag": "",
      "wf_id": {
        "$oid": "646b0f3c1e4a2d7f8e5b8c9e"
      },
      "dc_id": null,
      "dc_config": {},
      "cols_json": {},
      "parent_index": null,
      "last_updated": "2026-05-20T10:41:26.486019",
      "title_size": "sm",
      "title_align": "left",
      "order": 2,
      "alignment": "left",
      "body": "The Palmer Penguins dataset captures **physical measurements**\n(bill length / depth, flipper length, body mass) and **demographic\ncontext** (island, sex, year) for three species \u2014 *Adelie*,\n*Chinstrap*, *Gentoo* \u2014 sampled across Biscoe, Dream, and Torgersen\nislands. Both DCs are joined into a single canonical view. Cards\nexpose cohort centre + spread (box-plot strips), top-N species/island\ndominance, and a sample coverage gauge. The figures cover the\nbivariate body-mass \u00d7 flipper-length space and the sex \u00d7 species bill\nstructure.\n",
      "wf_tag": "python/penguin_species_analysis"
    },
