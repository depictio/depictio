      "last_updated": "2026-05-20T15:19:25.013773",
      "description": "Scatter matrix across all four measurements (seaborn deep palette). Off-diagonal = pairwise scatter, diagonal = per-variable distribution.",
      "title_size": "h3",
      "title_align": "left",
      "visu_type": "scatter",
      "dict_kwargs": {},
      "mode": "code",
      "code_content": "df_pd = df.to_pandas()\nfig = px.scatter_matrix(\n    df_pd,\n    dimensions=['sepal.length', 'sepal.width', 'petal.length', 'petal.width'],\n    color='variety',\n    color_discrete_map={'Setosa': '#4C72B0', 'Versicolor': '#DD8452', 'Virginica': '#55A467'},\n    labels={'sepal.length': 'Sepal L', 'sepal.width': 'Sepal W', 'petal.length': 'Petal L', 'petal.width': 'Petal W'},\n)\nfig.update_traces(diagonal_visible=True, showupperhalf=True, marker=dict(size=4, opacity=0.75, line=dict(width=0.4, color='white')))\nfig.update_layout(dragmode='select')\n",
      "displayed_data_count": 0,
      "total_data_count": 0,
      "was_sampled": false,
      "filter_applied": false,
      "selection_enabled": false,
      "selection_column": null,
      "wf_tag": "python/iris_workflow"
