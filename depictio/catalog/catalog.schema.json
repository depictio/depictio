{
  "$defs": {
    "CatalogFind": {
      "additionalProperties": false,
      "description": "How to recognise this tool output among the files in a run directory.\n\nMirrors MultiQC's search_patterns: a filename glob (`fn`), a content match\n(`contents`), plus depictio extras (a path glob and a tabular column check).\nA file matches when *all* of the declared conditions hold.",
      "properties": {
        "filename": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Filename"
        },
        "path_glob": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Path Glob"
        },
        "content_contains": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Content Contains"
        },
        "required_columns": {
          "items": {
            "type": "string"
          },
          "title": "Required Columns",
          "type": "array"
        }
      },
      "title": "CatalogFind",
      "type": "object"
    },
    "CatalogModule": {
      "additionalProperties": false,
      "description": "A tool (module). Carries the resolvable bio.tools / nf-core / EDAM identity.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        },
        "homepage": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Homepage"
        },
        "nf_core_module": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Nf Core Module"
        },
        "biotools_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Biotools Id"
        },
        "edam_topics": {
          "items": {
            "type": "string"
          },
          "title": "Edam Topics",
          "type": "array"
        }
      },
      "required": [
        "id",
        "name"
      ],
      "title": "CatalogModule",
      "type": "object"
    },
    "CatalogOutput": {
      "additionalProperties": false,
      "description": "One file a tool emits, in one running mode \u2192 one visualisation mapping.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        },
        "mode": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Mode"
        },
        "nf_core_module": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Nf Core Module"
        },
        "biotools_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Biotools Id"
        },
        "edam_operations": {
          "items": {
            "type": "string"
          },
          "title": "Edam Operations",
          "type": "array"
        },
        "edam_formats": {
          "items": {
            "type": "string"
          },
          "title": "Edam Formats",
          "type": "array"
        },
        "pipelines": {
          "items": {
            "type": "string"
          },
          "title": "Pipelines",
          "type": "array"
        },
        "find": {
          "$ref": "#/$defs/CatalogFind"
        },
        "read_options": {
          "$ref": "#/$defs/CatalogReadOptions"
        },
        "file_schema": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "File Schema",
          "type": "object"
        },
        "reshape": {
          "$ref": "#/$defs/CatalogReshape"
        },
        "feeds_viz": {
          "items": {
            "enum": [
              "volcano",
              "embedding",
              "manhattan",
              "stacked_taxonomy",
              "phylogenetic",
              "rarefaction",
              "da_barplot",
              "enrichment",
              "complex_heatmap",
              "upset_plot",
              "ma",
              "dot_plot",
              "lollipop",
              "qq",
              "sunburst",
              "oncoplot",
              "coverage_track",
              "sankey"
            ],
            "type": "string"
          },
          "title": "Feeds Viz",
          "type": "array"
        },
        "role_mapping": {
          "additionalProperties": {
            "additionalProperties": {
              "type": "string"
            },
            "type": "object"
          },
          "propertyNames": {
            "enum": [
              "volcano",
              "embedding",
              "manhattan",
              "stacked_taxonomy",
              "phylogenetic",
              "rarefaction",
              "da_barplot",
              "enrichment",
              "complex_heatmap",
              "upset_plot",
              "ma",
              "dot_plot",
              "lollipop",
              "qq",
              "sunburst",
              "oncoplot",
              "coverage_track",
              "sankey"
            ]
          },
          "title": "Role Mapping",
          "type": "object"
        }
      },
      "required": [
        "id",
        "find"
      ],
      "title": "CatalogOutput",
      "type": "object"
    },
    "CatalogReadOptions": {
      "additionalProperties": false,
      "description": "How to read the raw file into a DataFrame.",
      "properties": {
        "format": {
          "default": "csv",
          "enum": [
            "csv",
            "tsv",
            "parquet"
          ],
          "title": "Format",
          "type": "string"
        },
        "separator": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Separator"
        },
        "comment_prefix": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Comment Prefix"
        },
        "skip_rows": {
          "default": 0,
          "title": "Skip Rows",
          "type": "integer"
        },
        "has_header": {
          "default": true,
          "title": "Has Header",
          "type": "boolean"
        }
      },
      "title": "CatalogReadOptions",
      "type": "object"
    },
    "CatalogReshape": {
      "additionalProperties": false,
      "description": "Declarative reshape from the raw file's shape to a viz-ready shape.\n\n`kind=\"recipe\"` is the escape hatch for arbitrary logic and points at an\nexisting `projects/<pipeline>/recipes/<name>.py` transform.",
      "properties": {
        "kind": {
          "default": "identity",
          "enum": [
            "identity",
            "melt",
            "pivot",
            "aggregate",
            "recipe"
          ],
          "title": "Kind",
          "type": "string"
        },
        "id_vars": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Id Vars"
        },
        "value_vars": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value Vars"
        },
        "variable_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Variable Name"
        },
        "value_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value Name"
        },
        "index": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Index"
        },
        "on": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "On"
        },
        "values": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Values"
        },
        "group_by": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Group By"
        },
        "agg": {
          "anyOf": [
            {
              "enum": [
                "sum",
                "mean",
                "median",
                "max",
                "min",
                "count"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Agg"
        },
        "recipe": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Recipe"
        }
      },
      "title": "CatalogReshape",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "One module + all of its outputs (assembled from a file or a folder).",
  "properties": {
    "schema_version": {
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "module": {
      "$ref": "#/$defs/CatalogModule"
    },
    "outputs": {
      "items": {
        "$ref": "#/$defs/CatalogOutput"
      },
      "minItems": 1,
      "title": "Outputs",
      "type": "array"
    }
  },
  "required": [
    "module",
    "outputs"
  ],
  "title": "CatalogEntry",
  "type": "object"
}
