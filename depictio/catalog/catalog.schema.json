{
  "$defs": {
    "CatalogFind": {
      "additionalProperties": false,
      "description": "How to recognise the raw output file among a scanned run's files.",
      "properties": {
        "filename": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Filename"
        },
        "path_glob": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Path Glob"
        }
      },
      "title": "CatalogFind",
      "type": "object"
    },
    "CatalogOutput": {
      "additionalProperties": false,
      "description": "One file a tool emits \u2192 one or more dashboard renders.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "mode": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Mode"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        },
        "find": {
          "$ref": "#/$defs/CatalogFind"
        },
        "recipe": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Recipe"
        },
        "columns": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Columns",
          "type": "object"
        },
        "renders_as": {
          "items": {
            "$ref": "#/$defs/Render"
          },
          "title": "Renders As",
          "type": "array"
        },
        "nf_core_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Nf Core Url"
        },
        "biotools_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Biotools Url"
        },
        "edam_operations": {
          "items": {
            "type": "string"
          },
          "title": "Edam Operations",
          "type": "array"
        },
        "edam_formats": {
          "items": {
            "type": "string"
          },
          "title": "Edam Formats",
          "type": "array"
        }
      },
      "required": [
        "id",
        "find"
      ],
      "title": "CatalogOutput",
      "type": "object"
    },
    "Render": {
      "additionalProperties": false,
      "description": "One render target for an output: a component + its role\u2192column binding.",
      "properties": {
        "component": {
          "anyOf": [
            {
              "enum": [
                "card",
                "figure",
                "interactive",
                "table",
                "text",
                "jbrowse",
                "image",
                "map",
                "advanced_viz"
              ],
              "type": "string"
            },
            {
              "const": "multiqc",
              "type": "string"
            }
          ],
          "title": "Component"
        },
        "kind": {
          "anyOf": [
            {
              "enum": [
                "volcano",
                "embedding",
                "manhattan",
                "stacked_taxonomy",
                "phylogenetic",
                "rarefaction",
                "da_barplot",
                "enrichment",
                "complex_heatmap",
                "upset_plot",
                "ma",
                "dot_plot",
                "lollipop",
                "qq",
                "sunburst",
                "oncoplot",
                "coverage_track",
                "sankey"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Kind"
        },
        "roles": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Roles",
          "type": "object"
        },
        "section": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Section"
        }
      },
      "required": [
        "component"
      ],
      "title": "Render",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "A tool + all its outputs (one flat file, or a folder of files).",
  "properties": {
    "id": {
      "title": "Id",
      "type": "string"
    },
    "name": {
      "title": "Name",
      "type": "string"
    },
    "description": {
      "default": "",
      "title": "Description",
      "type": "string"
    },
    "homepage": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Homepage"
    },
    "nf_core_url": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Nf Core Url"
    },
    "biotools_url": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Biotools Url"
    },
    "edam_topics": {
      "items": {
        "type": "string"
      },
      "title": "Edam Topics",
      "type": "array"
    },
    "schema_version": {
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "outputs": {
      "items": {
        "$ref": "#/$defs/CatalogOutput"
      },
      "minItems": 1,
      "title": "Outputs",
      "type": "array"
    }
  },
  "required": [
    "id",
    "name",
    "outputs"
  ],
  "title": "CatalogEntry",
  "type": "object"
}
