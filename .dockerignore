# -----------------------------
# Viewer build output
# -----------------------------
# Produced inside the image by the viewer-builder stage in
# Dockerfile_depictio_uv.dockerfile. Excluding it from the docker context
# prevents a stale host bundle from clobbering the freshly-built one.
depictio/viewer/dist/

# -----------------------------
# Exclude Legacy Directories
# -----------------------------
depictioDB_K8S/
depictioDB_bak/
depictio-example-data/
jbrowse2_sessions/
jbrowse-watcher-plugin/
minio_data/

# -----------------------------
# Exclude Common Development Directories
# -----------------------------
dev/
bak/
data/
assets/
docs/
keys/
venv/
wf_data/

# Exclude generated screenshots, but keep the committed reference-dashboard
# thumbnails so the backend image ships them — the helm `copy-screenshot-files`
# init container copies /app/depictio/api/static/screenshots/*.png into the
# shared volume on startup.
screenshots/
!depictio/api/static/screenshots/

# -----------------------------
# Exclude Tests (not needed in production image)
# -----------------------------
depictio/tests/
tests/
*.test.js
*.spec.js
cypress/
pytest.ini
conftest.py

# -----------------------------
# Exclude Hidden Directories and Files
# -----------------------------
.depictio/

# -----------------------------
# Exclude Virtual Environments in Local Packages
# -----------------------------
# Any local dev venv anywhere in the tree — e.g. depictio/cli/.venv (~430 MB),
# created by the cli-venv workflow. Without this it lands in the `COPY depictio/`
# layer and bloats every image. Kept broad so new sub-project venvs can't
# silently re-bloat the build context.
**/.venv/
.venv/
packages/*/.git/
packages/*/.ruff_cache/
packages/*/.pytest_cache/

# -----------------------------
# Exclude Python Cache and Log Files
# -----------------------------
__pycache__/
*.log

# -----------------------------
# Exclude Node.js Dependencies (if applicable)
# -----------------------------
node_modules/

# -----------------------------
# Exclude Temporary Files and OS Files
# -----------------------------
*.tmp
*.swp
.DS_Store
Thumbs.db

# -----------------------------
# Secrets / local env — never bake these into an image layer
# -----------------------------
# Keeps .env / .env.* files and any TLS keypairs/certs out of the build
# context so they can't leak into image history. None of the api/worker/
# viewer builds need these — config is injected at runtime via env vars.
.env*
*.pem
*.key
*.crt
