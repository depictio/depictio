# Development environment — NOT for production
# Run: docker compose --file docker-compose.dev.yaml up -d

# ----------------------------------------------------------------------------
# Docker Compose
# ----------------------------------------------------------------------------
DATA_DIR=data

# ----------------------------------------------------------------------------
# Auth
# ----------------------------------------------------------------------------
DEPICTIO_AUTH_SINGLE_USER_MODE=true
DEPICTIO_AUTH_PUBLIC_MODE=false
DEPICTIO_AUTH_DEMO_MODE=false

# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------
DEPICTIO_MONGODB_WIPE=false

# ----------------------------------------------------------------------------
# Storage (MinIO) — DEV ONLY
# ----------------------------------------------------------------------------
# These credentials are tracked by the password-strength validator
# (>=16 chars, not in the well-known weak-password list). They are NOT
# suitable for any production / shared / internet-exposed deployment —
# generate fresh secrets via `openssl rand -base64 24` and supply them
# through a private .env or Kubernetes Secret.
DEPICTIO_MINIO_ROOT_USER=depictio_dev
DEPICTIO_MINIO_ROOT_PASSWORD=dev_minio_secret_x3uG7q9Wz2

# ----------------------------------------------------------------------------
# Bootstrap admin — DEV ONLY (replaces the legacy initial_users.yaml seed)
# ----------------------------------------------------------------------------
# First-boot admin for the dev cluster. Idempotent: once the user exists,
# password rotations via the UI stick across restarts. Override in real
# deployments via Helm secrets / SealedSecrets — never reuse these strings.
DEPICTIO_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
DEPICTIO_BOOTSTRAP_ADMIN_PASSWORD=dev_admin_secret_4Ks8r2qZpvm6
# CI / Cypress fixture user — kept enabled for the dev compose so existing
# tests and the manual sign-in story continue to work zero-touch.
DEPICTIO_BOOTSTRAP_SEED_TEST_USER=true
DEPICTIO_BOOTSTRAP_TEST_USER_EMAIL=test_user@example.com
DEPICTIO_BOOTSTRAP_TEST_USER_PASSWORD=test_pwd

# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------
DEPICTIO_CONTEXT=server
DEPICTIO_LOGGING_VERBOSITY_LEVEL=INFO
DEPICTIO_CELERY_ENABLED=false
DEPICTIO_DEV_MODE=true
DEPICTIO_DASHBOARD_YAML_MVP_MODE=true

# ----------------------------------------------------------------------------
# Real-time events (WebSocket live updates)
# ----------------------------------------------------------------------------
# Enables the /depictio/api/v1/events/ws WebSocket endpoint + the React
# viewer's RealtimeIndicator. Indicator only appears for projects whose
# project.yaml carries `realtime: { enabled: true }` (e.g. adapt_feedb_ms).
DEPICTIO_EVENTS_ENABLED=true
# MongoDB change streams require a replica set (not available in dev compose).
# Leaving this off; use POST /events/test-trigger/{dc_id} or your data
# producer (e.g. SVLT) to drive events instead.
DEPICTIO_EVENTS_MONGODB_CHANGE_STREAMS_ENABLED=false
