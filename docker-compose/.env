# Development environment — NOT for production
# Run: docker compose --file docker-compose.dev.yaml up -d

# ----------------------------------------------------------------------------
# Docker Compose
# ----------------------------------------------------------------------------
DATA_DIR=data

# ----------------------------------------------------------------------------
# Auth
# ----------------------------------------------------------------------------
DEPICTIO_AUTH_SINGLE_USER_MODE=true
DEPICTIO_AUTH_PUBLIC_MODE=false
DEPICTIO_AUTH_DEMO_MODE=false

# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------
DEPICTIO_MONGODB_WIPE=false

# ----------------------------------------------------------------------------
# Storage (MinIO)
# ----------------------------------------------------------------------------
DEPICTIO_MINIO_ROOT_USER=minio
DEPICTIO_MINIO_ROOT_PASSWORD=minio123

# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------
DEPICTIO_CONTEXT=server
DEPICTIO_LOGGING_VERBOSITY_LEVEL=INFO
DEPICTIO_CELERY_ENABLED=false
DEPICTIO_DEV_MODE=true
DEPICTIO_DASHBOARD_YAML_MVP_MODE=true

# ----------------------------------------------------------------------------
# Real-time events (WebSocket live updates)
# ----------------------------------------------------------------------------
# Enables the /depictio/api/v1/events/ws WebSocket endpoint + the React
# viewer's RealtimeIndicator. Indicator only appears for projects whose
# project.yaml carries `realtime: { enabled: true }` (e.g. adapt_feedb_ms).
DEPICTIO_EVENTS_ENABLED=true
# MongoDB change streams require a replica set (not available in dev compose).
# Leaving this off; use POST /events/test-trigger/{dc_id} or your data
# producer (e.g. SVLT) to drive events instead.
DEPICTIO_EVENTS_MONGODB_CHANGE_STREAMS_ENABLED=false
